{
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "diffEditor.ignoreTrimWhitespace": true
  },
  "[json][jsonc][javascript][javascriptreact][typescript][typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[django-html]": {
    "editor.defaultFormatter": "monosans.djlint"
  },
  "autoDocstring.startOnNewLine": true,
  "debug.console.wordWrap": false,
  "debug.inlineValues": "off",
  "debug.internalConsoleOptions": "neverOpen",
  "debug.onTaskErrors": "debugAnyway",
  "debug.openDebug": "neverOpen",
  "debug.showInStatusBar": "always",
  "debug.showSubSessionsInToolBar": true,
  "editor.inlineSuggest.enabled": true,
  "editor.wordWrap": "on",
  "git.mergeEditor": true,
  "githubPullRequests.commentExpandState": "collapseAll",
  "githubPullRequests.fileListLayout": "tree",
  "githubPullRequests.pullBranch": "never",
  "npm.keybindingsChangedWarningShown": true,
  "search.useGlobalIgnoreFiles": true,
  "terminal.integrated.cursorStyle": "line",
  "typescript.preferences.importModuleSpecifier": "relative",
  "window.commandCenter": false,
  "workbench.colorTheme": "Default Dark+",
  "workbench.editor.enablePreviewFromCodeNavigation": true,
  "workbench.editor.enablePreviewFromQuickOpen": true,
  "editor.formatOnType": false,
  "mypy.runUsingActiveInterpreter": true,
  "eslint.format.enable": true,
  // "git.openDiffOnClick": false,
  "window.zoomLevel": 1,
  "editor.stickyScroll.enabled": true,
  "editor.accessibilitySupport": "off",
  "ruff.codeAction.disableRuleComment": {
    "enable": false
  },
  "editor.formatOnPaste": false,
  "workbench.activityBar.orientation": "vertical",
  "cursor.chat.terminalShowHoverHint": false,
  "[html]": {
    "editor.defaultFormatter": "monosans.djlint"
  },
  "ruff.configuration": "./pyproject.toml",
  "djlint.configuration": "./pyproject.toml",
  "i18n-ally.autoDetection": false,
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "git.blame.editorDecoration.enabled": false,
  "python.testing.autoTestDiscoverOnSavePattern": "./tienda/**/*.py",
  "gitlens.views.commits.files.layout": "tree",
  "gitlens.views.scm.grouped.views": {
    "commits": true,
    "branches": true,
    "remotes": true,
    "stashes": true,
    "tags": true,
    "worktrees": true,
    "contributors": true,
    "fileHistory": false,
    "repositories": true,
    "searchAndCompare": true,
    "launchpad": false
  },
  "terminal.integrated.scrollback": 5000,
  "cursor.composer.queueMessageDefaultBehavior": "stop-and-send",
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "git.detectWorktrees": false,
  "window.autoDetectColorScheme": false,
}
